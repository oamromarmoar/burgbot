# Copy this file to .env and fill in real values, or export these as
# actual environment variables before running bot.py.
#
# Only DISCORD_TOKEN is required. Everything else here is just the *default*
# for servers that haven't run /setup yet -- the in-Discord setup wizard is
# the recommended way to configure each server (roles, channels, thresholds,
# welcome messages), and its values override these.

DISCORD_TOKEN=your-bot-token-here

# Feature 1: Referrals
REFERRAL_ROLE_ID=123456789012345678
REFERRALS_NEEDED=5

# Feature 1: Anti-abuse
MIN_ACCOUNT_AGE_SECONDS=259200
MIN_MEMBER_RETENTION_SECONDS=86400
SUSPICIOUS_LOG_CHANNEL_ID=123456789012345678

# Feature 2: Ticket role removal
CHEF_ROLE_ID=123456789012345678
TICKET_DETECTION_MODE=and
TICKET_CHANNEL_PREFIX=ticket-
TICKET_CATEGORY_ID=123456789012345678
ROLE_REMOVAL_DELAY_SECONDS=1200

# Optional activity-log channel (0 = disabled)
LOG_CHANNEL_ID=0

# Optional
BOT_DATA_DIR=./data
COMMAND_PREFIX=!
